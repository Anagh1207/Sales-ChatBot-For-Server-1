# Copy to `.env` in the `project/` directory and adjust values.

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/business_chatbot

# Excel paths (relative to project root when running uvicorn from project/)
SALES_EXCEL_PATH=data/Sales.xlsx
TIMESHEET_EXCEL_PATH=data/Timesheet.xlsx

# Optional per-salesperson quotas (JSON). Used for "met target" style questions.
# Example matches display names in Sales.xlsx.
SALES_QUOTAS_JSON={"Mike Johnson": 120000, "JJ Smith": 90000, "Alex Lee": 80000}
DEFAULT_SALES_QUOTA_GBP=200000

# OpenRouter (optional; improves low-confidence intent parsing)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
